# Copy this file to server/.env for production use, or server/.env.local for
# local development.  The docker-compose.yml passes these to the containers.
#
# Environment variables marked #REQ do not have a default and must be set.

# ============================================================================
# Container image names
# ============================================================================
# How the images will be tagged.  Changing these lets you run multiple
# versions side-by-side (e.g. staging / production).
SERVER_IMAGE=revodesign-pssm-gremlin-server-non-root
RUNNER_IMAGE=revodesign-pssm-gremlin-non-root

# ============================================================================
# Host paths — must exist on the Docker host
# ============================================================================
# Root directory for uploads, results, and the SQLite task database.
SERVER_DIR=/Users/yyy/Documents/protein_design/REvoDesign/playground/server_test
# Directory for Gunicorn and Celery log files.
LOG_DIR=/Users/yyy/Documents/protein_design/REvoDesign/playground/server_test/revodesign/server/logs

# ============================================================================
# MSA databases — large read-only datasets mounted into the runner container
# ============================================================================
# Prefix for the UniRef30 HHblits database (the directory containing the .cs219
# and .a3m files; omit extensions).
DB_UNIREF30=/Users/yyy/Documents/protein_design/REvoDesign/playground/miniuc/uc30/miniuc30
# Prefix for the UniRef90 BLAST database (the directory containing the .pin/.phr
# etc. files; omit extensions).
DB_UNIREF90=/Users/yyy/Documents/protein_design/REvoDesign/playground/miniuc/uc90/uniref90

# ============================================================================
# Authentication — token signing and user database
# ============================================================================
# Secret key for signing auth tokens.  #REQ in production: set a fixed,
# high-entropy value (e.g. `openssl rand -hex 32`) so tokens survive
# gunicorn/celery restarts.  If left empty a random key is generated per
# process, which breaks tokens after every restart.
# AUTH_SECRET_KEY=
# Token lifetime in seconds (default: 604800 = 7 days).
# AUTH_TOKEN_MAX_AGE=604800
# Path to the SQLite user database.  Defaults to {SERVER_DIR}/users.sqlite3.
# Move this outside SERVER_DIR for multi-process gunicorn deployments.
# USER_DB_PATH=

# ============================================================================
# Registration — self-service account creation (requires email service)
# ============================================================================
# Set to true to show the /register page and enable the registration API.
ENABLE_REGISTER=false
# Password for the default admin account, only used when the user database
# is empty (first bootstrap).  Change immediately after first login.
# DEFAULT_ADMIN_PASSWORD=

# ============================================================================
# Email — verification, password-reset, and admin notifications
# ============================================================================
# SMTP (stdlib, always available — no extra dependencies).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_FROM_ADDR=noreply@revodesign.local
# SMTP_FROM_NAME=REvoDesign GREMLIN Server

# Resend (pip extra 'resend', takes priority over SMTP when the package is
# installed with the [resend] extra and RESEND_API_KEY is non-empty).
# https://resend.com/
# RESEND_API_KEY=re_...
# RESEND_FROM_ADDR=onboarding@resend.dev
# RESEND_FROM_NAME=REvoDesign GREMLIN Server

# Public base URL used to generate links in verification, password-reset,
# and admin-digest emails.  Defaults to http://localhost:8080.
# SERVER_BASE_URL=http://localhost:8080

# Comma-separated list of allowed email domains for self-registration.
# Empty (default) = all domains allowed.  Also normalises plus-aliased
# addresses (user+tag@domain → user@domain).
# Example: "institution.edu,lab.org"
# ALLOWED_EMAIL_DOMAINS=

# Admin new-user digest: a background thread in the web process periodically
# emails a table of registrations that haven't appeared in a prior digest.
# Each user is included only once (flagged in the DB after first send).
# Comma-separated list of admin email addresses to receive the digest.
# ADMIN_NOTIFY_EMAIL=admin@lab.org,admin2@lab.org
# Interval in minutes between digest emails.  Set to 0 (or leave unset) to
# disable the digest thread entirely.
# ADMIN_NEW_USER_INFORM=60

# ============================================================================
# Redis — message broker and result backend for Celery
# ============================================================================
# REDIS_PASSWORD=           # set to enable Redis AUTH
REDIS_URL=redis://redis:6379/0
BROKER_URL=redis://redis:6379/0
RESULT_BACKEND=redis://redis:6379/0

# ============================================================================
# Runner — resource limits and host identity
# ============================================================================
# Number of CPU cores exposed to each runner container.  Total concurrent
# jobs = WORKER_CONCURRENCY; total CPU usage ≈ NPROC × WORKER_CONCURRENCY.
NPROC=4
# Memory limit in GB passed to hhblits inside the runner.
MAXMEM=64

# ============================================================================
# Gunicorn / Celery — process sizing
# ============================================================================
# Gunicorn worker count for the Flask web process.
GUNICORN_WORKERS=2
# Celery worker concurrency (one Celery worker, this many subprocesses).
WORKER_CONCURRENCY=2

# ============================================================================
# Container user identity — the non-root uid/gid that the server and runner
# containers run as.  Must match a user on the Docker host for volume mounts
# (upload/results directories) to work correctly.
# ============================================================================
RUNNER_UID=503
# On macOS Docker Desktop / OrbStack the Docker socket group is often 0 (root);
# on Linux use the host docker group id (e.g. `getent group docker | cut -d: -f3`).
RUNNER_GID=20
RUNNER_USERNAME=revodesign
RUNNER_GROUP=revodesign_appgroup

# ============================================================================
# Server — network and visibility
# ============================================================================
# Public HTTP port.
PORT=8080
# Scope task dashboard to the logged-in user (false, default) or show all
# tasks to everyone (true, for public-facing deployments without auth).
PUBLIC_DASHBOARD=false

# ============================================================================
# Admin — access control
# ============================================================================
# Comma-separated list of usernames granted admin privileges (full access to
# all tasks, user management page, and admin API routes).
ADMIN_USERS=admin

# ============================================================================
# Logging
# ============================================================================
# Timezone for log timestamps (e.g. Europe/London, Asia/Shanghai, UTC).
TZ=Europe/London
