# Copy this file to server/.env and update the paths according to your host.
PSSM_GREMLIN_SERVER_IMAGE=revodesign-pssm-gremlin-server
PSSM_GREMLIN_RUNNER_IMAGE=revodesign-pssm-gremlin
PSSM_GREMLIN_SERVER_DIR=/srv/revodesign/server
PSSM_GREMLIN_DB_UNIREF30=/srv/databases/uniref30/UniRef30_2023_02
PSSM_GREMLIN_DB_UNIREF90=/srv/databases/uniref90/uniref90
PSSM_GREMLIN_USERS_FILE=/srv/revodesign/server/users.txt
PSSM_GREMLIN_REDIS_URL=redis://redis:6379/0
PSSM_GREMLIN_BROKER_URL=redis://redis:6379/0
PSSM_GREMLIN_RESULT_BACKEND=redis://redis:6379/0
PSSM_GREMLIN_PORT=8080
PSSM_GREMLIN_NPROC=16
PSSM_GREMLIN_GUNICORN_WORKERS=2
PSSM_GREMLIN_WORKER_CONCURRENCY=2
PSSM_GREMLIN_RUNNER_UID=1000
PSSM_GREMLIN_RUNNER_GID=1000
PSSM_GREMLIN_DOMAIN=revodesign.example.com
