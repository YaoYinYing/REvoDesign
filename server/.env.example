# Copy this file to server/.env.production for production use.

## How the images will be named
SERVER_IMAGE=revodesign-pssm-gremlin-server-non-root
RUNNER_IMAGE=revodesign-pssm-gremlin-non-root

## In which directory the server will run
SERVER_DIR=/Users/yyy/Documents/protein_design/REvoDesign/playground/server_test
LOG_DIR=/Users/yyy/Documents/protein_design/REvoDesign/playground/server_test/revodesign/server/logs

## Databases for MSA searching
DB_UNIREF30=/Users/yyy/Documents/protein_design/REvoDesign/playground/miniuc/uc30/miniuc30
DB_UNIREF90=/Users/yyy/Documents/protein_design/REvoDesign/playground/miniuc/uc90/uniref90

## ---- Token-based auth ----
## Secret key for signing auth tokens. Set to a fixed, high-entropy value
## in production so tokens survive restarts.
# AUTH_SECRET_KEY=
## Token lifetime in seconds (default: 604800 = 7 days)
# AUTH_TOKEN_MAX_AGE=604800
## Path to the user database (default: {SERVER_DIR}/users.sqlite3)
# USER_DB_PATH=
## Enable the registration endpoint (default: false)
ENABLE_REGISTER=false
## Default admin password used only when bootstrapping the first user.
## Change it after first login.
# DEFAULT_ADMIN_PASSWORD=

## ---- SMTP settings (required for email verification) ----
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_FROM_ADDR=noreply@revodesign.local
# SMTP_FROM_NAME=REvoDesign GREMLIN Server
## Public base URL for generating verification links
# SERVER_BASE_URL=http://localhost:8080
## Comma-separated list of allowed email domains for registration.
## Empty (default) = all domains allowed.  Example: "institution.edu,lab.org"
## Also normalises plus-aliased addresses (user+tag@domain → user@domain).
# ALLOWED_EMAIL_DOMAINS=

## redis settings
## Set REDIS_PASSWORD to enable Redis authentication.
# REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
BROKER_URL=redis://redis:6379/0
RESULT_BACKEND=redis://redis:6379/0

# Runner settings
## Maximum number to run the server: NPROC * WORKER_CONCURRENCY
NPROC=4
## Maximum memory, at GB
MAXMEM=64

## Gunicorn settings
GUNICORN_WORKERS=2

## Celery settings
WORKER_CONCURRENCY=2

## Runner user at local machine
RUNNER_UID=503
RUNNER_GID=20
RUNNER_USERNAME=revodesign
RUNNER_GROUP=revodesign_appgroup

## Server settings
PORT=8080

## Whether to enable the dashboard user isolation
PUBLIC_DASHBOARD=false

## Admin users, comma separated
ADMIN_USERS=admin

## Timezone setting for logging datetime
TZ=Europe/London
