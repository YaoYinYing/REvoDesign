# Copy this file to server/.env and update the paths according to your host.
SERVER_IMAGE=revodesign-pssm-gremlin-server-non-root
RUNNER_IMAGE=revodesign-pssm-gremlin-non-root
SERVER_DIR=/srv/revodesign/server
LOG_DIR=/srv/revodesign/server/logs
DB_PATH=/srv/revodesign/server/pssm_gremlin.sqlite3
DB_UNIREF30=/srv/databases/uniref30/UniRef30_2023_02
DB_UNIREF90=/srv/databases/uniref90/uniref90
USERS_FILE=/srv/revodesign/server/users.txt
REDIS_URL=redis://redis:6379/0
BROKER_URL=redis://redis:6379/0
RESULT_BACKEND=redis://redis:6379/0
PORT=8080
NPROC=16
GUNICORN_WORKERS=2
WORKER_CONCURRENCY=2
RUNNER_UID=1000
RUNNER_GID=1000
DOMAIN=0.0.0.0
