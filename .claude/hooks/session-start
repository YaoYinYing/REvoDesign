#!/usr/bin/env bash
# SessionStart hook for loopkit: inject the using-loopkit bootstrap skill as
# additionalContext so skills auto-trigger from turn 1 without the user
# having to remember they exist. Pattern lifted from obra/superpowers.
#
# Fires on startup + /clear + compaction — the three moments loopkit's
# skill routing gets rediscovered.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd)}"

BOOTSTRAP="${PLUGIN_ROOT}/skills/using-loopkit/SKILL.md"
if [ ! -f "$BOOTSTRAP" ]; then
  # Fallback: loopkit installed into a project via install.sh writes skills
  # to .claude/skills/. Try that path too.
  BOOTSTRAP="${PLUGIN_ROOT}/.claude/skills/using-loopkit/SKILL.md"
fi
[ -f "$BOOTSTRAP" ] || exit 0

body="$(cat "$BOOTSTRAP")"

# JSON-escape the body without pulling in jq/python.
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}
escaped="$(escape_for_json "$body")"

ctx="<EXTREMELY_IMPORTANT>\nThis project uses loopkit. Below is the using-loopkit bootstrap — the routing rules for all other loopkit skills. Read it BEFORE responding; invoke matching skills BEFORE any other action.\n\n${escaped}\n</EXTREMELY_IMPORTANT>"

# Claude Code expects hookSpecificOutput.additionalContext (nested).
# Other SDK-standard clients accept top-level additionalContext.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$ctx"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$ctx"
fi
exit 0
